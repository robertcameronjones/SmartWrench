# Twilio account credentials (Console → Account → API keys & tokens)
TWILIO_ACCOUNT_SID=AC_your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here

# The Twilio number you're testing with, in E.164 format
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Public HTTPS base URL Twilio will hit for the inbound webhook.
# When using ngrok this looks like: https://abcd-12-34-56-78.ngrok-free.app
# Required for request signature validation.
PUBLIC_BASE_URL=

# Set to "1" to skip Twilio request signature validation (dev only).
SKIP_SIGNATURE_VALIDATION=0

# Port the inbound webhook server listens on locally.
PORT=8000
