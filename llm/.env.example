# Provide whichever keys you'll use. LiteLLM picks the right one based on
# the --model string. Unset keys are simply unavailable.

# OpenRouter — one key, ~200 models. Free-tier models work without paying.
# Use with --model openrouter/<vendor>/<model>
OPENROUTER_API_KEY=

# Direct provider keys (use any combination)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=

# LiteLLM is verbose by default; set to 1 to silence its banner/warnings.
LITELLM_QUIET=1
