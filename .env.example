# Copy this to .env (at the workspace root) for local dev.
# In production these are set in the Render dashboard, NOT in a .env file.
#
# .env is gitignored. .env.example is committed as the documented reference.

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# Public base URL of the simulator (without trailing slash).
# Locally: your ngrok URL (e.g. https://abc123.ngrok-free.app)
# Production: the Render URL (e.g. https://kate-simulator.onrender.com)
# Used by sms/server.py to validate Twilio signatures.
PUBLIC_BASE_URL=https://your-public-url.example.com

# Set to "1" only for local debugging when you want to bypass signature
# validation (e.g. hitting /sms with curl). Leave unset in production.
# TWILIO_SKIP_VALIDATION=

# --- LLM (LiteLLM via OpenRouter) ---
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=openrouter/qwen/qwen3.6-35b-a3b

# --- ElevenLabs (Voice) ---
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_AGENT_ID=agent_...
ELEVENLABS_AGENT_PHONE_NUMBER_ID=PN...

# --- Operators + passwords (v2) ---
# Comma-separated id:password pairs. Each operator gets a private
# data namespace at data/users/<id>/, seeded from fixtures/ on first
# authenticated request. HTTP Basic Auth is always required; the
# browser's username IS the operator id.
# Defaults to demo:demo when unset (dev only; logged loudly).
# USERS=robert:hunter2,alice:s3cret,bob:p4ssword

# Label shown in the simulator topbar (e.g. "v1", "v2", "local").
# DEPLOYMENT_LABEL=local
