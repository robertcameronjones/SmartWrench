# Copy this file to `.env` and fill in your real values.
# Get a key at https://elevenlabs.io/app/settings/api-keys

ELEVENLABS_API_KEY=sk_your_key_here

# Optional: a default voice id used by scripts/tts.py
# Browse voices at https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Optional: a default conversational agent id used by scripts/agent.py
ELEVENLABS_AGENT_ID=

# Optional: the agent's assigned Twilio phone-number id (phnum_...)
# Used by scripts/trigger.py for outbound calls
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
